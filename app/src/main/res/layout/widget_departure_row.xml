<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/widget_departure_row_padding_vertical"
    android:baselineAligned="false"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivRouteIcon"
        android:layout_width="@dimen/widget_departure_row_icon_size"
        android:layout_height="@dimen/widget_departure_row_icon_size"
        android:layout_marginEnd="@dimen/widget_departure_row_icon_margin_end" />

    <TextView
        android:id="@+id/tvHeadsign"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@android:color/white"
        android:maxLines="1"
        android:gravity="center_vertical"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="11sp"
        android:autoSizeMaxTextSize="16sp"
        android:autoSizeStepGranularity="1sp"
        android:text="Destination" />

    <TextView
        android:id="@+id/tvTime1"
        android:layout_width="@dimen/widget_departure_time_cell_width"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="@dimen/widget_departure_time_cell_padding_horizontal"
        android:textSize="@dimen/widget_departure_time_max_text_size"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTime2"
        android:layout_width="@dimen/widget_departure_time_cell_width"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="@dimen/widget_departure_time_cell_padding_horizontal"
        android:textSize="@dimen/widget_departure_time_max_text_size"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTime3"
        android:layout_width="@dimen/widget_departure_time_cell_width"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="@dimen/widget_departure_time_cell_padding_horizontal"
        android:textSize="@dimen/widget_departure_time_max_text_size"
        android:textStyle="bold" />

</LinearLayout>
