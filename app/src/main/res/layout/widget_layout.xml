<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:background="@drawable/widget_ripple_background">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivAgencyLogo"
            android:layout_width="42dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tvStopName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="@string/station"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:gravity="center_vertical"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="11sp"
            android:autoSizeMaxTextSize="22sp"
            android:autoSizeStepGranularity="1sp" />

        <TextView
            android:id="@+id/tvFreshnessText"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical"
            android:gravity="center_vertical"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/ivRefreshIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="2dp"
            android:src="@drawable/ic_refresh"
            app:tint="#AAAAAA" />

    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        android:src="@android:color/transparent"
        android:background="#bdc1c7" />

    <!-- Arrivals + overflow -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/llArrivals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="6dp" />

        <TextView
            android:id="@+id/tvOverflowStatic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:gravity="center_horizontal"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:text="" />

    </FrameLayout>

</LinearLayout>