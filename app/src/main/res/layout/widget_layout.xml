<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black">

    <!-- Header row -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/llHeaderInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/widget_header_padding_start"
            android:paddingTop="12dp"
            android:paddingBottom="6dp"
            android:background="@drawable/widget_ripple_overlay">

            <ImageView
                android:id="@+id/ivAgencyLogo"
                android:layout_width="@dimen/widget_agency_logo_width"
                android:layout_height="30dp"
                android:layout_marginEnd="@dimen/widget_agency_logo_margin_end"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tvStopName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/widget_stop_name_margin_end"
                android:text="@string/station"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center_vertical" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/llRefresh"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="6dp"
            android:paddingStart="@dimen/widget_go_mode_padding_horizontal"
            android:paddingEnd="@dimen/widget_go_mode_padding_horizontal"
            android:background="@drawable/widget_ripple_overlay">

            <TextView
                android:id="@+id/tvFreshnessText"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:gravity="center_vertical"
                android:textColor="@color/widget_color_secondary"
                android:textSize="@dimen/widget_freshness_text_size"
                android:layout_marginEnd="@dimen/widget_freshness_text_margin_end" />

            <ImageView
                android:id="@+id/ivGoModeDot"
                android:layout_width="@dimen/widget_freshness_icon_size"
                android:layout_height="@dimen/widget_freshness_icon_size"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="@dimen/widget_freshness_icon_margin_end"
                android:src="@drawable/ic_go_mode_dot"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivRefreshIcon"
                android:layout_width="@dimen/widget_freshness_icon_size"
                android:layout_height="@dimen/widget_freshness_icon_size"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="@dimen/widget_freshness_icon_margin_end"
                android:src="@drawable/ic_refresh"
                app:tint="@color/widget_color_secondary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Body: separator + departures. Refresh tap target lives here, not on widgetRoot,
         to avoid RemoteViews parent+child double-fire with the header's tap target. -->
    <LinearLayout
        android:id="@+id/llBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/widget_ripple_background">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="4dp"
            android:src="@android:color/transparent"
            android:background="@color/widget_color_placeholder" />

        <!-- Departures + overflow -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:id="@+id/llDepartures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="6dp" />

            <LinearLayout
                android:id="@+id/llEmptyContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvOverflowStatic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:gravity="center_horizontal"
                android:textColor="@color/widget_color_secondary"
                android:textSize="13sp"
                android:text="" />

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
