<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="44dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="44dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/configure_widget"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="24sp"
            android:paddingBottom="28dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/agency"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:paddingBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerAgency"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_spinner"
            android:paddingHorizontal="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/search_for_a_stop"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:paddingTop="28dp"
            android:paddingBottom="8dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etStopSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/stop_search_hint"
                android:textColorHint="@color/text_hint"
                android:inputType="text"
                android:background="@drawable/bg_stop_results"
                android:paddingVertical="14dp"
                android:paddingStart="14dp"
                android:paddingEnd="48dp"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:minHeight="52dp" />

            <ImageButton
                android:id="@+id/btnClearSearch"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_clear"
                android:visibility="gone"
                android:contentDescription="Clear search" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/flStopResultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_stop_results"
            android:clipToOutline="true"
            android:visibility="gone">

            <ListView
                android:id="@+id/lvStopResults"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:divider="@color/border_color"
                android:dividerHeight="1dp"
                android:fadeScrollbars="false"
                android:scrollbarAlwaysDrawVerticalTrack="true"
                android:nestedScrollingEnabled="true"
                android:listSelector="@android:color/transparent"
                android:footerDividersEnabled="true" />

            <TextView
                android:id="@+id/tvNoResults"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:gravity="center"
                android:text="No results found"
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvSelectedStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/accent_color"
            android:paddingTop="16dp"
            android:paddingBottom="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvRoutesLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filter_routes_all_shown_by_default"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:paddingTop="28dp"
            android:paddingBottom="8dp" />

        <FrameLayout
            android:id="@+id/flRoutesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_stop_results"
            android:clipToOutline="true"
            android:visibility="gone">

            <io.github.pranavm716.transittime.widget.NonScrollableExpandableListView
                android:id="@+id/elvRoutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:groupIndicator="@null"
                android:divider="@color/border_color"
                android:dividerHeight="1dp"
                android:childDivider="@color/border_color"
                android:listSelector="@android:color/transparent"
                android:footerDividersEnabled="true" />

        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/display_options"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:paddingTop="28dp"
            android:paddingBottom="12dp" />

        <RadioGroup
            android:id="@+id/rgDisplayMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbRelative"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/display_relative"
                android:textColor="@color/text_radio"
                android:paddingVertical="10dp"
                android:checked="true"
                android:buttonTint="@color/radio_button_tint" />

            <RadioButton
                android:id="@+id/rbAbsolute"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/display_absolute"
                android:paddingVertical="10dp"
                android:textColor="@color/text_radio"
                android:buttonTint="@color/radio_button_tint" />

            <RadioButton
                android:id="@+id/rbHybrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/display_hybrid_prefix"
                android:paddingVertical="10dp"
                android:textColor="@color/text_radio"
                android:buttonTint="@color/radio_button_tint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="36dp"
                android:paddingBottom="12dp">

                <EditText
                    android:id="@+id/etHybridThreshold"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="@string/default_hybrid_threshold"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:background="@drawable/bg_stop_results"
                    android:padding="8dp"
                    android:minHeight="44dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/display_hybrid_suffix"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:paddingStart="12dp" />

            </LinearLayout>

        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/max_arrivals"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:paddingTop="28dp"
            android:paddingBottom="12dp" />

        <EditText
            android:id="@+id/etMaxArrivals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="@string/default_max_arrivals"
            android:background="@drawable/bg_stop_results"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:minHeight="52dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/add_widget"
            android:layout_marginTop="40dp"
            android:backgroundTint="@color/accent_color"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
