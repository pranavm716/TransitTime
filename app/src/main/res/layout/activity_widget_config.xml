<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="44dp"
    android:paddingHorizontal="24dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/configure_widget"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#E6EDF3"
        android:paddingBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/agency"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:textColor="#7D8590"
        android:paddingBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerAgency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/search_for_a_stop"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:textColor="#7D8590"
        android:paddingTop="20dp"
        android:paddingBottom="4dp" />

    <EditText
        android:id="@+id/etStopSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/stop_search_hint"
        android:textColorHint="#4D5562"
        android:inputType="text" />

    <ListView
        android:id="@+id/lvStopResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false"
        android:background="@drawable/bg_stop_results"
        android:fadeScrollbars="false"
        android:scrollbarAlwaysDrawVerticalTrack="true"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvNoResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No results"
        android:textSize="14sp"
        android:textColor="#7D8590"
        android:background="@drawable/bg_stop_results"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvSelectedStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#58A6FF"
        android:paddingTop="10dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvRoutesLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/filter_routes_all_shown_by_default"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:textColor="#7D8590"
        android:paddingTop="16dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <ExpandableListView
        android:id="@+id/elvRoutes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false"
        android:background="@drawable/bg_stop_results"
        android:groupIndicator="@null"
        android:fadeScrollbars="false"
        android:scrollbarAlwaysDrawVerticalTrack="true"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="#30363D" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/display_options"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:textColor="#7D8590"
        android:paddingTop="16dp"
        android:paddingBottom="4dp" />

    <RadioGroup
        android:id="@+id/rgDisplayMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/rbRelative"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/display_relative"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbAbsolute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/display_absolute" />

        <RadioButton
            android:id="@+id/rbHybrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/display_hybrid_prefix" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="40dp"
            android:paddingBottom="4dp">

            <EditText
                android:id="@+id/etHybridThreshold"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="@string/default_hybrid_threshold"
                android:gravity="center"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/display_hybrid_suffix"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp" />

        </LinearLayout>

    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/max_arrivals"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:textColor="#7D8590"
        android:paddingTop="16dp"
        android:paddingBottom="4dp" />

    <EditText
        android:id="@+id/etMaxArrivals"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:text="@string/default_max_arrivals" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add_widget"
        android:layout_marginTop="20dp" />

</LinearLayout>
