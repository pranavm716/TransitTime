<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingBottom="24dp"
    android:paddingTop="50dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/configure_widget"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="16dp" />

    <!-- Agency picker -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/agency" />

    <Spinner
        android:id="@+id/spinnerAgency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Stop search -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/search_for_a_stop"
        android:paddingTop="16dp" />

    <EditText
        android:id="@+id/etStopSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/stop_search_hint"
        android:inputType="text" />

    <!-- Search results -->
    <ListView
        android:id="@+id/lvStopResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="4dp"
        android:visibility="gone" />

    <!-- Selected stop confirmation -->
    <TextView
        android:id="@+id/tvSelectedStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:paddingTop="8dp"
        android:visibility="gone" />

    <!-- Max arrivals -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/max_arrivals"
        android:paddingTop="16dp" />

    <EditText
        android:id="@+id/etMaxArrivals"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:text="@string/default_max_arrivals" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add_widget"
        android:layout_marginTop="16dp" />

</LinearLayout>